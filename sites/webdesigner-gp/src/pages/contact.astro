---
import Layout from '../layouts/Layout.astro'
import ContactForm from '../components/ContactForm.tsx'

const jsonLd = [{
  '@context': 'https://schema.org', '@type': 'ContactPage',
  name: 'Contact — Web Designer Guadeloupe',
  url: 'https://webdesigner.sakaybrile.uk/contact/',
  breadcrumb: { '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://webdesigner.sakaybrile.uk/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://webdesigner.sakaybrile.uk/contact/' },
  ]},
}]
---
<Layout
  title="Contact — Devis Création Site Internet Guadeloupe | Sakaybrile"
  description="Contactez votre web designer en Guadeloupe. Devis gratuit sous 24h pour la création de votre site internet. Réponse rapide garantie."
  jsonLd={jsonLd}
>
  <section class="section">
    <div class="container" style="max-width:640px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <span class="badge">Contact</span>
        <h1 style="margin-top:1rem;">Demandez votre devis gratuit</h1>
        <p style="margin-top:0.75rem;">Décrivez votre projet et je vous envoie une proposition personnalisée sous 24h.</p>
      </div>
      <ContactForm client:load />
    </div>
  </section>
</Layout>
