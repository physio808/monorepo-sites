<style>
  .breadcrumb { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 0.75rem 0; font-size: 0.875rem; }
  .breadcrumb ol { list-style: none; display: flex; gap: 0.5rem; align-items: center; }
  .breadcrumb a { color: var(--color-primary); text-decoration: none; }

  .legal-page { padding: 4rem 0; }
  .legal-page h1 { font-size: 2.25rem; margin-bottom: 0.5rem; }
  .legal-updated { color: #94a3b8; font-size: 0.9rem; margin-bottom: 3rem; }

  .legal-section { margin-bottom: 2.5rem; }
  .legal-section h2 { font-size: 1.25rem; color: var(--color-primary); border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin-bottom: 1rem; }
  .legal-section p { color: #475569; line-height: 1.8; margin-bottom: 0.75rem; }
  .legal-section ul { padding-left: 1.5rem; color: #475569; line-height: 1.8; }
  .legal-section li { margin-bottom: 0.25rem; }
  .legal-section a { color: var(--color-primary); }

  .legal-contact { background: #f0f9ff; border-radius: 0.75rem; padding: 1.5rem; margin-top: 2rem; }
  .legal-contact p { color: #475569; margin: 0; }
  .legal-contact a { color: var(--color-primary); font-weight: 600; }
</style>
