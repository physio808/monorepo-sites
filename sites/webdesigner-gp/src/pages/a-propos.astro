---
import Layout from '../layouts/Layout.astro';

const jsonLdPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sakaybrile",
  "jobTitle": "Webdesigner & Développeur Web",
  "description": "Webdesigner freelance en Guadeloupe, spécialisé en création de sites internet professionnels, e-commerce et référencement SEO local depuis 2019.",
  "url": "https://webdesigner.sakaybrile.uk",
  "sameAs": [
    "https://www.linkedin.com/in/sakaybrile",
    "https://www.instagram.com/sakaybrile_web"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Pointe-à-Pitre",
    "addressRegion": "Guadeloupe",
    "postalCode": "97110",
    "addressCountry": "GP"
  },
  "knowsAbout": [
    "Création de site internet",
    "Webdesign",
    "SEO local",
    "E-commerce",
    "Astro.js",
    "React",
    "Référencement naturel Guadeloupe"
  ],
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "name": "Google Analytics Certified" },
    { "@type": "EducationalOccupationalCredential", "name": "Développeur Web certifié" }
  ]
};

const jsonLdAboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "À propos — Webdesigner Guadeloupe | Sakaybrile",
  "description": "Découvrez qui je suis : webdesigner freelance en Guadeloupe depuis 2019, je crée des sites internet rapides, beaux et optimisés SEO pour les entrepreneurs et PME antillais.",
  "url": "https://webdesigner.sakaybrile.uk/a-propos",
  "mainEntity": { "@type": "Person", "name": "Sakaybrile" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://webdesigner.sakaybrile.uk" },
      { "@type": "ListItem", "position": 2, "name": "À propos", "item": "https://webdesigner.sakaybrile.uk/a-propos" }
    ]
  }
};
---

<Layout
  title="À propos — Webdesigner Freelance Guadeloupe | Sakaybrile"
  description="Webdesigner freelance en Guadeloupe depuis 2019. Je crée des sites internet professionnels, e-commerce et optimisés SEO pour entrepreneurs et PME en Guadeloupe et Antilles."
  canonical="https://webdesigner.sakaybrile.uk/a-propos"
  jsonLd={[jsonLdPerson, jsonLdAboutPage]}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Fil d'Ariane">
    <div class="container">
      <ol>
        <li><a href="/">Accueil</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">À propos</li>
      </ol>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__grid">
        <div class="about-hero__content">
          <p class="about-hero__eyebrow">Webdesigner Guadeloupe depuis 2019</p>
          <h1>Créateur de <span class="highlight">présences web</span> qui génèrent des clients</h1>
          <p class="about-hero__lead">
            Je m'appelle Sakaybrile, webdesigner freelance basé à Pointe-à-Pitre.
            Mon métier : transformer votre expertise en un site internet qui travaille pour vous
            24h/24, attire vos clients idéaux et renforce votre crédibilité.
          </p>
          <div class="about-hero__ctas">
            <a href="/contact" class="btn btn--primary">Discutons de votre projet</a>
            <a href="/portfolio" class="btn btn--outline">Voir mes réalisations</a>
          </div>
        </div>
        <div class="about-hero__image">
          <div class="profile-card">
            <div class="profile-card__avatar">
              <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="60" cy="60" r="60" fill="#0e7490" opacity="0.1"/>
                <circle cx="60" cy="45" r="22" fill="#0e7490"/>
                <path d="M20 110 Q60 75 100 110" fill="#0e7490"/>
              </svg>
            </div>
            <div class="profile-card__info">
              <strong>Sakaybrile</strong>
              <span>Webdesigner & Dev Web</span>
              <span class="badge">📍 Guadeloupe</span>
            </div>
            <div class="profile-card__stats">
              <div><strong>50+</strong><span>Sites créés</span></div>
              <div><strong>5 ans</strong><span>d'expérience</span></div>
              <div><strong>98%</strong><span>clients satisfaits</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mon histoire -->
  <section class="section bg-light">
    <div class="container">
      <div class="story">
        <div class="story__content">
          <h2>Mon histoire</h2>
          <p>
            Tout a commencé en 2019 avec un constat simple : de nombreux entrepreneurs guadeloupéens
            avaient des produits et services excellents, mais une présence en ligne inexistante ou
            inefficace. Des concurrents moins compétents mais mieux visibles leur prenaient des clients.
          </p>
          <p>
            J'ai alors décidé de me spécialiser dans la création de sites internet pour les acteurs
            locaux de Guadeloupe — artisans, commerçants, professions libérales, TPE/PME — avec une
            obsession : créer des sites qui <strong>convertissent des visiteurs en clients</strong>,
            pas juste de jolis vitrines.
          </p>
          <p>
            Depuis, j'ai accompagné plus de 50 professionnels en Guadeloupe, Martinique et dans
            l'hexagone. Chaque projet est unique, chaque client mérite une solution sur mesure.
          </p>
        </div>
        <div class="story__values">
          <h3>Ce qui me différencie</h3>
          <ul class="values-list">
            <li>
              <span class="values-list__icon">⚡</span>
              <div>
                <strong>Performance avant tout</strong>
                <p>Sites en 2-3 secondes de chargement — Google l'exige, vos clients l'apprécient</p>
              </div>
            </li>
            <li>
              <span class="values-list__icon">🎯</span>
              <div>
                <strong>SEO local Guadeloupe</strong>
                <p>Vos clients vous cherchent sur Google : je m'assure qu'ils vous trouvent</p>
              </div>
            </li>
            <li>
              <span class="values-list__icon">🤝</span>
              <div>
                <strong>Accompagnement humain</strong>
                <p>Je suis local, disponible, je parle votre langue et je comprends votre marché</p>
              </div>
            </li>
            <li>
              <span class="values-list__icon">📱</span>
              <div>
                <strong>100% mobile-first</strong>
                <p>Plus de 70% de vos visiteurs arrivent sur mobile — aucun compromis</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Mes compétences -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Mes compétences techniques</h2>
      <p class="section-subtitle">Des technologies modernes pour des sites pérennes et performants</p>
      <div class="skills-grid">
        <div class="skill-category">
          <h3>Frontend</h3>
          <ul>
            <li><span class="skill-tag">Astro.js</span></li>
            <li><span class="skill-tag">React</span></li>
            <li><span class="skill-tag">Next.js</span></li>
            <li><span class="skill-tag">HTML5 / CSS3</span></li>
            <li><span class="skill-tag">TypeScript</span></li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>E-commerce</h3>
          <ul>
            <li><span class="skill-tag">WooCommerce</span></li>
            <li><span class="skill-tag">Shopify</span></li>
            <li><span class="skill-tag">Stripe</span></li>
            <li><span class="skill-tag">PayPlug</span></li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>SEO & Analytics</h3>
          <ul>
            <li><span class="skill-tag">Google Search Console</span></li>
            <li><span class="skill-tag">Google Analytics 4</span></li>
            <li><span class="skill-tag">SEMrush</span></li>
            <li><span class="skill-tag">Schema.org / JSON-LD</span></li>
          </ul>
        </div>
        <div class="skill-category">
          <h3>Infrastructure</h3>
          <ul>
            <li><span class="skill-tag">Cloudflare</span></li>
            <li><span class="skill-tag">Vercel / Netlify</span></li>
            <li><span class="skill-tag">Linux / VPS</span></li>
            <li><span class="skill-tag">Git / GitHub</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Mon processus -->
  <section class="section bg-light">
    <div class="container">
      <h2 class="section-title">Comment je travaille</h2>
      <p class="section-subtitle">Un processus clair, sans surprises</p>
      <div class="process-timeline">
        <div class="process-step">
          <div class="process-step__number">1</div>
          <div class="process-step__content">
            <h3>Découverte (gratuit)</h3>
            <p>Appel ou rencontre de 30 min pour comprendre votre activité, vos objectifs, votre budget et votre planning.</p>
            <p class="process-step__duration">⏱ Durée : 30 min</p>
          </div>
        </div>
        <div class="process-step">
          <div class="process-step__number">2</div>
          <div class="process-step__content">
            <h3>Devis & Stratégie</h3>
            <p>Je vous envoie un devis détaillé avec le cahier des charges, les maquettes et le planning de livraison.</p>
            <p class="process-step__duration">⏱ Délai : 48h</p>
          </div>
        </div>
        <div class="process-step">
          <div class="process-step__number">3</div>
          <div class="process-step__content">
            <h3>Design & Développement</h3>
            <p>Je crée votre site avec des points d'étape réguliers. Vous validez chaque phase et pouvez demander des ajustements.</p>
            <p class="process-step__duration">⏱ Délai : 2-6 semaines</p>
          </div>
        </div>
        <div class="process-step">
          <div class="process-step__number">4</div>
          <div class="process-step__content">
            <h3>Livraison & Formation</h3>
            <p>Mise en ligne, tests complets, formation à l'utilisation et remise de toutes les accès. Votre site est entre vos mains.</p>
            <p class="process-step__duration">⏱ Durée : 2h de formation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Prêt à travailler ensemble ?</h2>
        <p>Prenez contact gratuitement, sans engagement. Je vous réponds sous 24h.</p>
        <a href="/contact" class="btn btn--primary btn--large">Demander un devis gratuit</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 0.75rem 0; font-size: 0.875rem; }
  .breadcrumb ol { list-style: none; display: flex; gap: 0.5rem; align-items: center; }
  .breadcrumb a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .about-hero { padding: 4rem 0 5rem; background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); }
  .about-hero__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .about-hero__eyebrow { color: var(--color-primary); font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 0.75rem; }
  .about-hero h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; margin-bottom: 1.25rem; }
  .about-hero__lead { font-size: 1.1rem; color: #475569; line-height: 1.7; margin-bottom: 2rem; }
  .about-hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  .profile-card { background: white; border-radius: 1rem; padding: 2rem; box-shadow: 0 10px 40px rgba(0,0,0,0.1); text-align: center; }
  .profile-card__avatar { width: 100px; height: 100px; margin: 0 auto 1rem; }
  .profile-card__avatar svg { width: 100%; height: 100%; border-radius: 50%; }
  .profile-card__info { margin-bottom: 1.5rem; }
  .profile-card__info strong { display: block; font-size: 1.25rem; }
  .profile-card__info span { display: block; color: #64748b; font-size: 0.9rem; }
  .badge { display: inline-block !important; margin-top: 0.5rem; background: #f0fdf4; color: #16a34a; padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.8rem !important; }
  .profile-card__stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; border-top: 1px solid #f1f5f9; padding-top: 1.5rem; }
  .profile-card__stats strong { display: block; font-size: 1.5rem; color: var(--color-primary); }
  .profile-card__stats span { font-size: 0.75rem; color: #64748b; }

  .story { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .story__content h2 { margin-bottom: 1.5rem; }
  .story__content p { color: #475569; line-height: 1.8; margin-bottom: 1rem; }
  .story__values h3 { margin-bottom: 1.5rem; }
  .values-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  .values-list li { display: flex; gap: 1rem; }
  .values-list__icon { font-size: 1.5rem; flex-shrink: 0; }
  .values-list strong { display: block; margin-bottom: 0.25rem; }
  .values-list p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .skills-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .skill-category h3 { font-size: 1rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-primary); }
  .skill-category ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .skill-tag { background: #f1f5f9; color: #334155; padding: 0.35rem 0.75rem; border-radius: 0.4rem; font-size: 0.85rem; display: inline-block; }

  .process-timeline { display: flex; flex-direction: column; gap: 0; }
  .process-step { display: flex; gap: 2rem; position: relative; padding-bottom: 2.5rem; }
  .process-step:not(:last-child)::before { content: ''; position: absolute; left: 1.25rem; top: 2.5rem; bottom: 0; width: 2px; background: var(--color-primary); opacity: 0.2; }
  .process-step__number { width: 2.5rem; height: 2.5rem; border-radius: 50%; background: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
  .process-step__content h3 { margin-bottom: 0.5rem; }
  .process-step__content p { color: #475569; line-height: 1.6; margin-bottom: 0.5rem; }
  .process-step__duration { font-size: 0.85rem; color: var(--color-primary); font-weight: 500; }

  .cta-section { background: linear-gradient(135deg, var(--color-primary) 0%, #0369a1 100%); }
  .cta-box { text-align: center; color: white; padding: 3rem; }
  .cta-box h2 { color: white; font-size: 2rem; margin-bottom: 1rem; }
  .cta-box p { color: rgba(255,255,255,0.9); font-size: 1.1rem; margin-bottom: 2rem; }

  .highlight { color: var(--color-primary); }

  @media (max-width: 768px) {
    .about-hero__grid, .story, .skills-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: repeat(2, 1fr); }
    .about-hero__ctas { flex-direction: column; }
  }
</style>
