---
import Layout from '../layouts/Layout.astro'
import TypedText from '../components/TypedText.astro'
import AnimatedCounter from '../components/AnimatedCounter.astro'

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Web Designer Guadeloupe — Création Site Internet | Sakaybrile',
    url: 'https://webdesigner.sakaybrile.uk/',
    description: 'Web designer indépendant en Guadeloupe. Création de sites internet professionnels, SEO et e-commerce. Devis gratuit sous 24h.',
    breadcrumb: { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://webdesigner.sakaybrile.uk/' }] },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Combien coûte la création d\'un site internet en Guadeloupe ?', acceptedAnswer: { '@type': 'Answer', text: 'Le prix d\'un site vitrine professionnel en Guadeloupe varie entre 800€ et 3000€ selon les fonctionnalités souhaitées. Un site e-commerce démarre à partir de 2000€. Demandez votre devis gratuit pour une estimation précise.' } },
      { '@type': 'Question', name: 'Combien de temps faut-il pour créer un site internet ?', acceptedAnswer: { '@type': 'Answer', text: 'La création d\'un site vitrine prend en moyenne 3 à 5 semaines. Un site e-commerce nécessite 6 à 10 semaines. Ces délais incluent la phase de conception, développement, tests et mise en ligne.' } },
      { '@type': 'Question', name: 'Proposez-vous le référencement SEO en Guadeloupe ?', acceptedAnswer: { '@type': 'Answer', text: 'Oui, chaque site est optimisé SEO dès la création : structure technique, mots-clés locaux Guadeloupe, vitesse de chargement, balises méta et données structurées.' } },
    ],
  },
]

const stats = [
  { value: '50+', label: 'Sites créés en Guadeloupe' },
  { value: '98%', label: 'Clients satisfaits' },
  { value: '5 ans', label: "d'expérience web" },
  { value: '24h', label: 'Délai de réponse devis' },
]

const services = [
  {
    icon: '🖥️',
    title: 'Création Site Vitrine',
    desc: 'Site professionnel, rapide et optimisé SEO pour présenter votre activité en Guadeloupe. Design sur-mesure adapté à votre image de marque.',
    href: '/services/creation-site-vitrine/',
    price: 'À partir de 800€',
  },
  {
    icon: '🛒',
    title: 'Site E-commerce',
    desc: 'Boutique en ligne complète pour vendre vos produits en Guadeloupe et dans toute la Caraïbe. Paiement sécurisé, gestion stocks.',
    href: '/services/creation-site-ecommerce/',
    price: 'À partir de 2000€',
  },
  {
    icon: '📈',
    title: 'Référencement SEO',
    desc: "Apparaissez en première page Google pour les recherches liées à votre activité en Guadeloupe. Audit, optimisation et suivi mensuel.",
    href: '/services/referencement-seo/',
    price: 'À partir de 300€/mois',
  },
]
---

<Layout
  title="Web Designer Guadeloupe — Création Site Internet | Sakaybrile"
  description="Web designer indépendant en Guadeloupe 🇫🇷 Création de sites internet professionnels, e-commerce et référencement SEO. Devis gratuit sous 24h."
  jsonLd={jsonLd}
>

  <!-- ═══ HERO ═══ -->
  <section style="background:linear-gradient(135deg,#0c4a6e 0%,#0e7490 50%,#0891b2 100%);color:white;padding:6rem 0 5rem;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:url('/grid.svg') center/60px repeat;opacity:0.07;"></div>
    <div class="container" style="position:relative;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">
      <div>
        <p class="badge" style="background:rgba(249,115,22,0.2);color:#fed7aa;margin-bottom:1.25rem;">
          🌴 Web Designer — Guadeloupe
        </p>
        <h1 style="color:white;margin-bottom:1.25rem;line-height:1.1;">
          Je suis <TypedText words={["Web Designer", "Développeur Web", "Expert SEO", "Créatif"]} /><br />
          <span style="color:#7dd3fc;">en Guadeloupe</span>
        </h1>
        <p style="color:#bae6fd;font-size:1.125rem;margin-bottom:2rem;line-height:1.7;">
          Vous avez besoin d'un site internet professionnel en Guadeloupe ?
          Je crée des sites rapides, beaux et optimisés SEO pour que vos clients vous trouvent sur Google.
        </p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href="/contact/" class="btn btn-primary" style="background:var(--color-accent);border-color:var(--color-accent);">
            Devis gratuit en 24h →
          </a>
          <a href="/portfolio/" class="btn btn-outline" style="border-color:rgba(255,255,255,0.4);color:white;">
            Voir mes réalisations
          </a>
        </div>
        <p style="margin-top:1.5rem;font-size:0.85rem;color:#93c5fd;">
          ✓ Réponse sous 24h &nbsp;·&nbsp; ✓ Devis gratuit &nbsp;·&nbsp; ✓ Sans engagement
        </p>
      </div>
      <div style="display:flex;justify-content:center;">
        <div style="background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);border-radius:1.5rem;padding:2rem;border:1px solid rgba(255,255,255,0.2);max-width:400px;width:100%;">
          <div style="background:rgba(255,255,255,0.05);border-radius:0.75rem;padding:1.25rem;margin-bottom:1rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
              <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#f59e0b;"></div>
              <div style="width:12px;height:12px;border-radius:50%;background:#10b981;"></div>
            </div>
            <div style="height:8px;background:rgba(255,255,255,0.15);border-radius:4px;margin-bottom:8px;width:80%;"></div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-bottom:8px;width:60%;"></div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;width:70%;"></div>
          </div>
          <p style="text-align:center;font-weight:600;font-size:0.9rem;color:#e0f2fe;">
            🚀 Score Lighthouse : 98/100
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section style="padding:3rem 0;border-bottom:1px solid var(--color-border);">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;" data-stagger>
        <AnimatedCounter value={50} suffix="+" label="Sites créés en Guadeloupe" />
        <AnimatedCounter value={98} suffix="%" label="Clients satisfaits" />
        <AnimatedCounter value={5} suffix=" ans" label="d'expérience web" />
        <AnimatedCounter value={24} suffix="h" label="Délai de réponse devis" />
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="section" id="services">
    <div class="container">
      <div style="text-align:center;max-width:600px;margin:0 auto 3rem;" data-reveal>
        <span class="badge">Mes services</span>
        <h2 style="margin-top:1rem;">Création de sites internet en Guadeloupe</h2>
        <p style="margin-top:1rem;">Du site vitrine au e-commerce, j'accompagne les entrepreneurs guadeloupéens dans leur présence en ligne.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem;" data-stagger>
        {services.map(s => (
          <article style="border:1px solid var(--color-border);border-radius:var(--radius);padding:2rem;transition:box-shadow 0.2s;position:relative;overflow:hidden;">
            <span style="font-size:2.5rem;">{s.icon}</span>
            <h3 style="margin:1rem 0 0.75rem;color:var(--color-text);">{s.title}</h3>
            <p style="font-size:0.9rem;margin-bottom:1.25rem;">{s.desc}</p>
            <p style="font-weight:700;color:var(--color-primary);font-size:0.95rem;margin-bottom:1.25rem;">{s.price}</p>
            <a href={s.href} style="color:var(--color-primary);font-weight:600;font-size:0.9rem;display:flex;align-items:center;gap:0.25rem;">
              En savoir plus →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ POURQUOI MOI ═══ -->
  <section class="section section-alt">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div>
        <span class="badge">Pourquoi me choisir</span>
        <h2 style="margin-top:1rem;">Un web designer local qui comprend le marché guadeloupéen</h2>
        <p style="margin-top:1rem;margin-bottom:2rem;">Basé en Guadeloupe, je connais les spécificités de l'île : les habitudes de recherche locales, la concurrence par secteur, et les attentes des clients antillais.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:1rem;">
          {[
            ['⚡', 'Sites ultra-rapides', 'Score Google PageSpeed > 90/100 garanti'],
            ['🎯', 'SEO local Guadeloupe', 'Optimisé pour apparaître sur les recherches locales'],
            ['📱', 'Mobile-first', '70% de vos visiteurs arrivent sur mobile'],
            ['🤝', 'Accompagnement complet', 'De la conception à la mise en ligne et au-delà'],
          ].map(([icon, title, desc]) => (
            <li style="display:flex;gap:1rem;align-items:flex-start;">
              <span style="font-size:1.5rem;flex-shrink:0;">{icon}</span>
              <div>
                <p style="font-weight:600;color:var(--color-text);margin-bottom:0.25rem;">{title}</p>
                <p style="font-size:0.875rem;">{desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div style="background:var(--color-primary);color:white;padding:2.5rem;border-radius:var(--radius);">
        <h3 style="color:white;margin-bottom:1.5rem;">Processus en 4 étapes</h3>
        {[
          ['1', 'Analyse de vos besoins', 'Réunion gratuite pour comprendre votre activité et vos objectifs'],
          ['2', 'Conception & Design', 'Maquette personnalisée à votre image, validée par vous'],
          ['3', 'Développement', 'Site rapide, SEO-ready, testé sur tous les appareils'],
          ['4', 'Mise en ligne & Formation', 'Déploiement + formation pour gérer votre contenu'],
        ].map(([n, t, d]) => (
          <div style="display:flex;gap:1rem;margin-bottom:1.25rem;">
            <span style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;">{n}</span>
            <div>
              <p style="font-weight:600;color:#e0f2fe;">{t}</p>
              <p style="font-size:0.825rem;color:#bae6fd;margin-top:0.1rem;">{d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section" id="faq">
    <div class="container" style="max-width:800px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <span class="badge">FAQ</span>
        <h2 style="margin-top:1rem;">Questions fréquentes</h2>
      </div>
      {[
        ['Combien coûte la création d\'un site internet en Guadeloupe ?', 'Le prix d\'un site vitrine professionnel en Guadeloupe varie entre 800€ et 3000€ selon les fonctionnalités souhaitées. Un site e-commerce démarre à partir de 2000€. Je propose des devis transparents, sans surprise.'],
        ['Combien de temps faut-il pour créer un site internet ?', 'La création d\'un site vitrine prend en moyenne 3 à 5 semaines. Un site e-commerce nécessite 6 à 10 semaines. Ces délais incluent la conception, le développement, les tests et la mise en ligne.'],
        ['Proposez-vous le référencement SEO en Guadeloupe ?', 'Oui, chaque site est optimisé SEO dès la création. Je propose également des prestations SEO mensuelles pour améliorer votre positionnement sur Google pour les recherches locales en Guadeloupe.'],
        ['Pouvez-vous refondre mon site internet existant ?', 'Absolument. Je réalise des refontes complètes en conservant votre référencement existant et en améliorant les performances, le design et l\'expérience utilisateur.'],
        ['Serai-je autonome pour modifier mon site ?', 'Oui, je livre tous mes sites avec une interface d\'administration simple. Je propose également une formation d\'1h pour que vous puissiez gérer vos contenus en toute autonomie.'],
      ].map(([q, a]) => (
        <details style="border:1px solid var(--color-border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:0.75rem;">
          <summary style="font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            {q} <span>+</span>
          </summary>
          <p style="margin-top:1rem;font-size:0.9rem;">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA FINAL ═══ -->
  <section style="background:linear-gradient(135deg,var(--color-primary) 0%,var(--color-primary-dark) 100%);color:white;padding:5rem 0;text-align:center;">
    <div class="container" style="max-width:600px;margin:0 auto;">
      <h2 style="color:white;margin-bottom:1rem;">Prêt à lancer votre projet web en Guadeloupe ?</h2>
      <p style="color:#bae6fd;margin-bottom:2rem;">Obtenez un devis gratuit et personnalisé sous 24h. Sans engagement.</p>
      <a href="/contact/" class="btn btn-primary" style="background:var(--color-accent);border-color:var(--color-accent);font-size:1.1rem;padding:1rem 2.5rem;">
        Demander mon devis gratuit →
      </a>
    </div>
  </section>

</Layout>
