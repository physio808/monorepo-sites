---
import Layout from '../layouts/Layout.astro'
import TypedText from '../components/TypedText.astro'
import AnimatedCounter from '../components/AnimatedCounter.astro'
import MagneticButton from '../components/MagneticButton.astro'
import Marquee from '../components/Marquee.astro'

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Web Designer Guadeloupe — Création Site Internet | Sakaybrile',
    url: 'https://webdesigner.sakaybrile.uk/',
    description: 'Web designer indépendant en Guadeloupe. Création de sites internet professionnels, SEO et e-commerce. Devis gratuit sous 24h.',
    breadcrumb: { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://webdesigner.sakaybrile.uk/' }] },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Combien coûte la création d\'un site internet en Guadeloupe ?', acceptedAnswer: { '@type': 'Answer', text: 'Le prix d\'un site vitrine professionnel en Guadeloupe varie entre 800€ et 3000€ selon les fonctionnalités souhaitées. Un site e-commerce démarre à partir de 2000€. Demandez votre devis gratuit pour une estimation précise.' } },
      { '@type': 'Question', name: 'Combien de temps faut-il pour créer un site internet ?', acceptedAnswer: { '@type': 'Answer', text: 'La création d\'un site vitrine prend en moyenne 3 à 5 semaines. Un site e-commerce nécessite 6 à 10 semaines. Ces délais incluent la phase de conception, développement, tests et mise en ligne.' } },
      { '@type': 'Question', name: 'Proposez-vous le référencement SEO en Guadeloupe ?', acceptedAnswer: { '@type': 'Answer', text: 'Oui, chaque site est optimisé SEO dès la création : structure technique, mots-clés locaux Guadeloupe, vitesse de chargement, balises méta et données structurées.' } },
    ],
  },
]

const stats = [
  { value: '50+', label: 'Sites créés en Guadeloupe' },
  { value: '98%', label: 'Clients satisfaits' },
  { value: '5 ans', label: "d'expérience web" },
  { value: '24h', label: 'Délai de réponse devis' },
]

const services = [
  {
    icon: '🖥️',
    title: 'Création Site Vitrine',
    desc: 'Site professionnel, rapide et optimisé SEO pour présenter votre activité en Guadeloupe. Design sur-mesure adapté à votre image de marque.',
    href: '/services/creation-site-vitrine/',
    price: 'À partir de 800€',
  },
  {
    icon: '🛒',
    title: 'Site E-commerce',
    desc: 'Boutique en ligne complète pour vendre vos produits en Guadeloupe et dans toute la Caraïbe. Paiement sécurisé, gestion stocks.',
    href: '/services/creation-site-ecommerce/',
    price: 'À partir de 2000€',
  },
  {
    icon: '📈',
    title: 'Référencement SEO',
    desc: "Apparaissez en première page Google pour les recherches liées à votre activité en Guadeloupe. Audit, optimisation et suivi mensuel.",
    href: '/services/referencement-seo/',
    price: 'À partir de 300€/mois',
  },
]
---

<Layout
  title="Web Designer Guadeloupe — Création Site Internet | Sakaybrile"
  description="Web designer indépendant en Guadeloupe 🇫🇷 Création de sites internet professionnels, e-commerce et référencement SEO. Devis gratuit sous 24h."
  jsonLd={jsonLd}
>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <!-- Noise texture overlay -->
    <div class="hero__noise" aria-hidden="true"></div>
    <!-- Floating shapes -->
    <div class="hero__shape hero__shape--1" aria-hidden="true" data-parallax="0.2"></div>
    <div class="hero__shape hero__shape--2" aria-hidden="true" data-parallax="0.35"></div>
    <div class="hero__shape hero__shape--3" aria-hidden="true" data-parallax="0.15"></div>

    <div class="container hero__grid">
      <div class="hero__content">
        <div class="hero__eyebrow" data-gsap="fade-up">
          <span class="hero__dot" aria-hidden="true"></span>
          Web Designer · Guadeloupe
        </div>

        <h1 class="hero__title" data-split>
          Je crée des sites qui convertissent
        </h1>

        <p class="hero__lead" data-gsap="fade-up">
          Sites vitrine, e-commerce et SEO local pour entrepreneurs en Guadeloupe.
          Votre client vous cherche sur Google — je m'assure qu'il vous trouve.
        </p>

        <div class="hero__ctas" data-gsap="fade-up">
          <MagneticButton href="/contact/" variant="accent" size="lg">
            Devis gratuit en 24h →
          </MagneticButton>
          <MagneticButton href="/portfolio/" variant="outline" size="lg">
            Voir mes réalisations
          </MagneticButton>
        </div>

        <div class="hero__trust" data-gsap="fade-up">
          <div class="hero__trust-item"><span>✓</span> Réponse sous 24h</div>
          <div class="hero__trust-item"><span>✓</span> Sans engagement</div>
          <div class="hero__trust-item"><span>✓</span> 50+ sites livrés</div>
        </div>
      </div>

      <div class="hero__visual" data-gsap="fade-up">
        <!-- Card mockup glassmorphism -->
        <div class="hero__card" id="hero-tilt">
          <div class="hero__card-header">
            <span class="hero__card-dot" style="background:#ef4444"></span>
            <span class="hero__card-dot" style="background:#f59e0b"></span>
            <span class="hero__card-dot" style="background:#10b981"></span>
            <span class="hero__card-url">webdesigner.sakaybrile.uk</span>
          </div>
          <div class="hero__card-score">
            <div class="hero__score-ring">
              <svg viewBox="0 0 60 60" aria-label="Score Lighthouse 98">
                <circle cx="30" cy="30" r="24" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="4"/>
                <circle cx="30" cy="30" r="24" fill="none" stroke="#10b981" stroke-width="4"
                  stroke-dasharray="150.8" stroke-dashoffset="3" stroke-linecap="round"
                  transform="rotate(-90 30 30)"/>
              </svg>
              <span>98</span>
            </div>
            <div>
              <p class="hero__score-label">Lighthouse</p>
              <p class="hero__score-sub">Performance</p>
            </div>
          </div>
          <div class="hero__card-metrics">
            <div class="hero__metric">
              <span class="hero__metric-dot green"></span>
              <span>LCP</span><strong>0.8s</strong>
            </div>
            <div class="hero__metric">
              <span class="hero__metric-dot green"></span>
              <span>CLS</span><strong>0.00</strong>
            </div>
            <div class="hero__metric">
              <span class="hero__metric-dot green"></span>
              <span>INP</span><strong>12ms</strong>
            </div>
          </div>
          <div class="hero__card-badge">
            <span>⚡</span> Optimisé Cloudflare
          </div>
        </div>
        <!-- Urgency badge -->
        <div class="hero__urgency" aria-live="polite">
          <span class="hero__urgency-dot" aria-hidden="true"></span>
          <strong>2 créneaux</strong> disponibles ce mois
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <div class="hero__scroll-arrow">
        <svg width="16" height="24" viewBox="0 0 16 24"><path d="M8 0v20M1 13l7 7 7-7" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>
      </div>
    </div>
  </section>

  <!-- ═══ MARQUEE CLIENTS ═══ -->
  <section class="marquee-section" aria-label="Secteurs d'activité servis">
    <Marquee
      items={["Restaurants", "Artisans", "Médecins", "Avocats", "E-commerce", "Architectes", "Coaches", "Hôtels", "Photographes", "Consultants"]}
      speed={25}
      label="Secteurs clients"
    />
  </section>

  <!-- ═══ STATS FLIP CARDS ═══ -->
  <section class="stats-section">
    <div class="container">
      <p class="stats-headline" data-gsap="fade-up">Des résultats que vous pouvez mesurer</p>
      <div class="stats-grid" data-gsap-stagger>

        <div class="stat-flip" tabindex="0" aria-label="50+ sites créés — cliquer pour en savoir plus">
          <div class="stat-flip__inner">
            <div class="stat-flip__front">
              <div class="stat-flip__icon-wrap">🏝️</div>
              <div class="stat-flip__number" aria-live="polite">
                <span class="stat-count" data-target="50" data-suffix="+">0+</span>
              </div>
              <p class="stat-flip__label">Sites créés en Guadeloupe</p>
              <div class="stat-flip__bar"><div class="stat-flip__bar-fill" style="--pct:85%"></div></div>
              <span class="stat-flip__hint">Cliquer pour les secteurs →</span>
            </div>
            <div class="stat-flip__back">
              <div class="stat-back__icon">🏆</div>
              <p class="stat-back__title">Restaurants · Médecins · Artisans · Avocats · Hôtels · E-commerce</p>
              <p class="stat-back__text">Chaque secteur, une stratégie web adaptée aux habitudes locales guadeloupéennes.</p>
              <a href="/portfolio/" class="stat-back__cta">Voir le portfolio →</a>
            </div>
          </div>
        </div>

        <div class="stat-flip" tabindex="0" aria-label="98% clients satisfaits — cliquer pour témoignage">
          <div class="stat-flip__inner">
            <div class="stat-flip__front">
              <div class="stat-flip__icon-wrap">⭐</div>
              <div class="stat-flip__number">
                <span class="stat-count" data-target="98" data-suffix="%">0%</span>
              </div>
              <p class="stat-flip__label">Clients satisfaits</p>
              <div class="stat-flip__bar"><div class="stat-flip__bar-fill" style="--pct:98%"></div></div>
              <span class="stat-flip__hint">Cliquer pour un témoignage →</span>
            </div>
            <div class="stat-flip__back">
              <div class="stat-back__icon">💬</div>
              <p class="stat-back__quote">"Site livré en 4 semaines, 3× plus de contacts depuis la mise en ligne."</p>
              <p class="stat-back__author">— Restaurant Le Lagon, Pointe-à-Pitre</p>
              <a href="/a-propos/" class="stat-back__cta">Tous les avis →</a>
            </div>
          </div>
        </div>

        <div class="stat-flip" tabindex="0" aria-label="5 ans d'expérience — cliquer pour en savoir plus">
          <div class="stat-flip__inner">
            <div class="stat-flip__front">
              <div class="stat-flip__icon-wrap">🚀</div>
              <div class="stat-flip__number">
                <span class="stat-count" data-target="5" data-suffix=" ans">0 ans</span>
              </div>
              <p class="stat-flip__label">d'expérience web</p>
              <div class="stat-flip__bar"><div class="stat-flip__bar-fill" style="--pct:70%"></div></div>
              <span class="stat-flip__hint">Cliquer pour le parcours →</span>
            </div>
            <div class="stat-flip__back">
              <div class="stat-back__icon">📅</div>
              <p class="stat-back__title">Depuis 2019</p>
              <p class="stat-back__text">Web designer certifié, formé aux dernières technologies Astro, Cloudflare & SEO local Caraïbes.</p>
              <a href="/a-propos/" class="stat-back__cta">Mon parcours →</a>
            </div>
          </div>
        </div>

        <div class="stat-flip" tabindex="0" aria-label="Réponse en 24h — cliquer pour demander un devis">
          <div class="stat-flip__inner">
            <div class="stat-flip__front">
              <div class="stat-flip__icon-wrap">⚡</div>
              <div class="stat-flip__number">
                <span class="stat-count" data-target="24" data-suffix="h">0h</span>
              </div>
              <p class="stat-flip__label">Délai de réponse devis</p>
              <div class="stat-flip__bar"><div class="stat-flip__bar-fill" style="--pct:100%"></div></div>
              <span class="stat-flip__hint">Cliquer pour votre devis →</span>
            </div>
            <div class="stat-flip__back stat-flip__back--accent">
              <div class="stat-back__icon">📩</div>
              <p class="stat-back__title">Devis gratuit & personnalisé</p>
              <p class="stat-back__text">Décrivez votre projet, recevez une proposition détaillée sous 24h. Sans engagement.</p>
              <a href="/contact/" class="stat-back__cta stat-back__cta--white">Demander maintenant →</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header" data-gsap="fade-up">
        <span class="badge">Mes services</span>
        <h2 data-split style="margin-top:1rem;">Création de sites internet en Guadeloupe</h2>
        <p style="margin-top:1rem;">Du site vitrine au e-commerce, j'accompagne les entrepreneurs guadeloupéens dans leur présence en ligne.</p>
      </div>
      <div class="services-grid" data-gsap-stagger>
        {services.map(s => (
          <a href={s.href} class="service-card" data-tilt>
            <div class="service-card__glow" aria-hidden="true"></div>
            <div class="service-card__icon">{s.icon}</div>
            <h3 class="service-card__title">{s.title}</h3>
            <p class="service-card__desc">{s.desc}</p>
            <div class="service-card__footer">
              <span class="service-card__price">{s.price}</span>
              <span class="service-card__arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ POURQUOI MOI ═══ -->
  <section class="section section-alt">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div>
        <span class="badge">Pourquoi me choisir</span>
        <h2 style="margin-top:1rem;">Un web designer local qui comprend le marché guadeloupéen</h2>
        <p style="margin-top:1rem;margin-bottom:2rem;">Basé en Guadeloupe, je connais les spécificités de l'île : les habitudes de recherche locales, la concurrence par secteur, et les attentes des clients antillais.</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:1rem;">
          {[
            ['⚡', 'Sites ultra-rapides', 'Score Google PageSpeed > 90/100 garanti'],
            ['🎯', 'SEO local Guadeloupe', 'Optimisé pour apparaître sur les recherches locales'],
            ['📱', 'Mobile-first', '70% de vos visiteurs arrivent sur mobile'],
            ['🤝', 'Accompagnement complet', 'De la conception à la mise en ligne et au-delà'],
          ].map(([icon, title, desc]) => (
            <li style="display:flex;gap:1rem;align-items:flex-start;">
              <span style="font-size:1.5rem;flex-shrink:0;">{icon}</span>
              <div>
                <p style="font-weight:600;color:var(--color-text);margin-bottom:0.25rem;">{title}</p>
                <p style="font-size:0.875rem;">{desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div style="background:var(--color-primary);color:white;padding:2.5rem;border-radius:var(--radius);">
        <h3 style="color:white;margin-bottom:1.5rem;">Processus en 4 étapes</h3>
        {[
          ['1', 'Analyse de vos besoins', 'Réunion gratuite pour comprendre votre activité et vos objectifs'],
          ['2', 'Conception & Design', 'Maquette personnalisée à votre image, validée par vous'],
          ['3', 'Développement', 'Site rapide, SEO-ready, testé sur tous les appareils'],
          ['4', 'Mise en ligne & Formation', 'Déploiement + formation pour gérer votre contenu'],
        ].map(([n, t, d]) => (
          <div style="display:flex;gap:1rem;margin-bottom:1.25rem;">
            <span style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;">{n}</span>
            <div>
              <p style="font-weight:600;color:#e0f2fe;">{t}</p>
              <p style="font-size:0.825rem;color:#bae6fd;margin-top:0.1rem;">{d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section" id="faq">
    <div class="container" style="max-width:800px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <span class="badge">FAQ</span>
        <h2 style="margin-top:1rem;">Questions fréquentes</h2>
      </div>
      {[
        ['Combien coûte la création d\'un site internet en Guadeloupe ?', 'Le prix d\'un site vitrine professionnel en Guadeloupe varie entre 800€ et 3000€ selon les fonctionnalités souhaitées. Un site e-commerce démarre à partir de 2000€. Je propose des devis transparents, sans surprise.'],
        ['Combien de temps faut-il pour créer un site internet ?', 'La création d\'un site vitrine prend en moyenne 3 à 5 semaines. Un site e-commerce nécessite 6 à 10 semaines. Ces délais incluent la conception, le développement, les tests et la mise en ligne.'],
        ['Proposez-vous le référencement SEO en Guadeloupe ?', 'Oui, chaque site est optimisé SEO dès la création. Je propose également des prestations SEO mensuelles pour améliorer votre positionnement sur Google pour les recherches locales en Guadeloupe.'],
        ['Pouvez-vous refondre mon site internet existant ?', 'Absolument. Je réalise des refontes complètes en conservant votre référencement existant et en améliorant les performances, le design et l\'expérience utilisateur.'],
        ['Serai-je autonome pour modifier mon site ?', 'Oui, je livre tous mes sites avec une interface d\'administration simple. Je propose également une formation d\'1h pour que vous puissiez gérer vos contenus en toute autonomie.'],
      ].map(([q, a]) => (
        <details style="border:1px solid var(--color-border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-bottom:0.75rem;">
          <summary style="font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
            {q} <span>+</span>
          </summary>
          <p style="margin-top:1rem;font-size:0.9rem;">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══ CTA FINAL ═══ -->
  <!-- ═══ CTA FINAL ═══ -->
  <section class="cta-final">
    <div class="cta-final__noise" aria-hidden="true"></div>
    <div class="container">
      <p class="cta-final__eyebrow" data-gsap="fade-up">Prêt à démarrer ?</p>
      <h2 class="cta-final__title" data-split>Lançons votre projet ensemble</h2>
      <p class="cta-final__sub" data-gsap="fade-up">Devis gratuit et personnalisé sous 24h. Sans engagement.</p>
      <div data-gsap="fade-up" style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem;">
        <MagneticButton href="/contact/" variant="accent" size="lg">
          Demander mon devis gratuit →
        </MagneticButton>
        <MagneticButton href="/a-propos/" variant="outline" size="lg">
          En savoir plus
        </MagneticButton>
      </div>
      <p class="cta-final__reassurance" data-gsap="fade-up">
        ✓ Réponse sous 24h &nbsp;·&nbsp; ✓ 100% gratuit &nbsp;·&nbsp; ✓ Sans engagement &nbsp;·&nbsp; ✓ Basé en Guadeloupe
      </p>
    </div>
  </section>

</Layout>

<style>
/* ══════════════════════════════
   HERO
══════════════════════════════ */
.hero {
  background: linear-gradient(135deg, #070b14 0%, #0c1a2e 50%, #0e2038 100%);
  color: white;
  padding: 6rem 0 5rem;
  position: relative;
  overflow: hidden;
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Animated gradient background */
@property --hero-angle {
  syntax: '<angle>';
  initial-value: 135deg;
  inherits: false;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(var(--hero-angle), rgba(14,116,144,0.15) 0%, rgba(249,115,22,0.06) 50%, rgba(14,116,144,0.1) 100%);
  animation: hero-gradient 12s ease-in-out infinite alternate;
}
@keyframes hero-gradient {
  to { --hero-angle: 225deg; }
}

/* Noise texture */
.hero__noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.04;
  pointer-events: none;
  z-index: 1;
}

/* Floating shapes */
.hero__shape {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.hero__shape--1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(14,116,144,0.15), transparent 70%);
  top: -150px; right: -100px;
  animation: float1 8s ease-in-out infinite;
}
.hero__shape--2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(249,115,22,0.1), transparent 70%);
  bottom: 50px; left: -50px;
  animation: float2 10s ease-in-out infinite;
}
.hero__shape--3 {
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(14,116,144,0.2), transparent 70%);
  top: 30%; left: 40%;
  animation: float1 6s ease-in-out infinite reverse;
}
@keyframes float1 {
  0%, 100% { transform: translateY(0) scale(1); }
  50%       { transform: translateY(-30px) scale(1.05); }
}
@keyframes float2 {
  0%, 100% { transform: translateY(0) translateX(0); }
  50%       { transform: translateY(20px) translateX(15px); }
}

.hero__grid {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* Eyebrow */
.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1.5rem;
}
.hero__dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--color-accent, #f97316);
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.6); }
  50%       { box-shadow: 0 0 0 8px rgba(249,115,22,0); }
}

.hero__title {
  font-size: clamp(2.25rem, 5vw, 4rem);
  font-weight: 800;
  color: white;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
  overflow: hidden;
}

.hero__lead {
  color: rgba(255,255,255,0.65);
  font-size: 1.15rem;
  line-height: 1.75;
  margin-bottom: 2.5rem;
  max-width: 520px;
}

.hero__ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.hero__trust {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.hero__trust-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
