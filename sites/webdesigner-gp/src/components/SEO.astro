---
interface Props {
  title: string
  description: string
  canonical?: string
  image?: string
  type?: 'website' | 'article'
  publishDate?: Date
  jsonLd?: Record<string, unknown>[]
}

const SITE = 'https://webdesigner.sakaybrile.uk'
const BRAND = 'Sakaybrile Web Design'
const DEFAULT_IMAGE = `${SITE}/og-default.jpg`

const {
  title,
  description,
  canonical = Astro.url.href,
  image = DEFAULT_IMAGE,
  type = 'website',
  publishDate,
  jsonLd = [],
} = Astro.props

const fullTitle = title.includes(BRAND) ? title : `${title} | ${BRAND}`

// JSON-LD LocalBusiness (présent sur toutes les pages)
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE}/#business`,
  name: BRAND,
  description: 'Création de sites internet et référencement SEO en Guadeloupe',
  url: SITE,
  telephone: '+590-690-000000',
  email: 'contact@sakaybrile.uk',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Guadeloupe',
    addressLocality: 'Pointe-à-Pitre',
    postalCode: '97110',
    addressRegion: 'Guadeloupe',
    addressCountry: 'FR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 16.2650,
    longitude: -61.5510,
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '18:00',
  }],
  priceRange: '€€',
  areaServed: {
    '@type': 'Place',
    name: 'Guadeloupe',
  },
  serviceType: ['Création de site internet', 'Référencement SEO', 'Site e-commerce'],
  image: DEFAULT_IMAGE,
  sameAs: [],
}

const allJsonLd = [localBusiness, ...jsonLd]
---

<!-- Balises de base -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- SEO -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="author" content={BRAND} />

<!-- Langue et région -->
<meta name="language" content="fr-FR" />
<meta name="geo.region" content="GP" />
<meta name="geo.placename" content="Guadeloupe" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content={BRAND} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- Article dates si besoin -->
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Preconnect performances -->
<link rel="preconnect" href="https://fonts.googleapis.com" />

<!-- JSON-LD Structured Data -->
{allJsonLd.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
