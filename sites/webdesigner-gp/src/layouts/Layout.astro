---
import SEO from '../components/SEO.astro'
import ScrollReveal from '../components/ScrollReveal.astro'
import ScrollProgress from '../components/ScrollProgress.astro'
import Preloader from '../components/Preloader.astro'
import BackToTop from '../components/BackToTop.astro'
import FluidCursor from '../components/FluidCursor.astro'
import DarkModeToggle from '../components/DarkModeToggle.astro'
import SmoothScroll from '../components/SmoothScroll.astro'
import AnimationEngine from '../components/AnimationEngine.astro'
import { ViewTransitions } from 'astro:transitions'

interface Props {
  title: string
  description: string
  canonical?: string
  image?: string
  type?: 'website' | 'article'
  publishDate?: Date
  jsonLd?: Record<string, unknown>[]
}

const props = Astro.props
const pathname = Astro.url.pathname
---

<!doctype html>
<html lang="fr">
<head>
  <SEO {...props} />
  <ViewTransitions />
  <link rel="stylesheet" href="/dark-mode.css" />
  <style is:global>
    @import '@fontsource/plus-jakarta-sans/latin-400.css';
    @import '@fontsource/plus-jakarta-sans/latin-600.css';
    @import '@fontsource/plus-jakarta-sans/latin-700.css';
    @import '@fontsource/plus-jakarta-sans/latin-800.css';
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --color-primary: #0e7490;
      --color-primary-dark: #0c4a6e;
      --color-accent: #f97316;
      --color-text: #1e293b;
      --color-text-light: #64748b;
      --color-bg: #ffffff;
      --color-bg-alt: #f8fafc;
      --color-border: #e2e8f0;
      --font-sans: 'Plus Jakarta Sans Variable', 'Inter', system-ui, -apple-system, sans-serif;
      --radius: 0.75rem;
      --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
      --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
      --max-w: 1200px;
    }
    html { font-family: var(--font-sans); color: var(--color-text); background: var(--color-bg); scroll-behavior: smooth; }
    body { min-height: 100vh; display: flex; flex-direction: column; cursor: none; }
    @media (hover: none) { body { cursor: auto; } }
    main { flex: 1; }
    img { max-width: 100%; height: auto; }
    a { color: inherit; text-decoration: none; }
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.25rem; }
    .section { padding: 5rem 0; }
    .bg-light { background: var(--color-bg-alt); }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.875rem 1.75rem; border-radius: var(--radius);
      font-weight: 600; font-size: 1rem; cursor: pointer;
      transition: all 0.25s ease; border: 2px solid transparent;
      text-decoration: none;
    }
    .btn--primary { background: var(--color-primary); color: white; }
    .btn--primary:hover { background: var(--color-primary-dark); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(14,116,144,0.35); }
    .btn--outline { border-color: var(--color-primary); color: var(--color-primary); background: transparent; }
    .btn--outline:hover { background: var(--color-primary); color: white; transform: translateY(-2px); }
    .btn--large { padding: 1rem 2.5rem; font-size: 1.1rem; }
    .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; background: #e0f2fe; color: var(--color-primary); }
    h1, h2, h3, h4 { line-height: 1.2; font-weight: 700; color: var(--color-text); }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
    h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); }
    h3 { font-size: 1.25rem; }
    p { line-height: 1.7; color: var(--color-text-light); }
    .section-title { text-align: center; margin-bottom: 1rem; }
    .section-subtitle { text-align: center; color: var(--color-text-light); max-width: 600px; margin: 0 auto 3rem; }
    @media (max-width: 768px) { .section { padding: 3rem 0; } }

    /* ── Highlight text ── */
    .highlight { color: var(--color-primary); }

    /* ── Gradient text ── */
    .gradient-text {
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Navigation active state ── */
    .nav-link { font-weight: 500; position: relative; padding-bottom: 2px; }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--color-primary);
      transition: width 0.3s ease;
    }
    .nav-link:hover::after, .nav-link.active::after { width: 100%; }

    /* ── Mobile menu ── */
    #mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10,10,15,0.97);
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }
    #mobile-menu.open { display: flex; }
    #mobile-menu a { color: white; font-size: 1.5rem; font-weight: 700; }
    #mobile-menu a:hover { color: var(--color-accent); }

    @media (max-width: 768px) {
      .nav-desktop { display: none !important; }
      .nav-mobile-btn { display: flex !important; }
    }
    .nav-mobile-btn { display: none; }
  </style>
  <ScrollReveal />
</head>
<body>
  <ScrollProgress />

  <!-- Mobile Menu -->
  <div id="mobile-menu" role="dialog" aria-label="Menu principal" aria-modal="true">
    <button id="mobile-close" aria-label="Fermer le menu" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;color:white;font-size:2rem;cursor:pointer;">✕</button>
    <a href="/" onclick="document.getElementById('mobile-menu').classList.remove('open')">Accueil</a>
    <a href="/services/" onclick="document.getElementById('mobile-menu').classList.remove('open')">Services</a>
    <a href="/portfolio/" onclick="document.getElementById('mobile-menu').classList.remove('open')">Portfolio</a>
    <a href="/blog/" onclick="document.getElementById('mobile-menu').classList.remove('open')">Blog</a>
    <a href="/contact/" onclick="document.getElementById('mobile-menu').classList.remove('open')" style="background:var(--color-primary);color:white;padding:0.75rem 2rem;border-radius:0.5rem;">Devis gratuit</a>
  </div>

  <!-- HEADER -->
  <header id="site-header">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:4.5rem;">
      <a href="/" style="font-weight:800;font-size:1.35rem;color:var(--color-primary);letter-spacing:-0.02em;">
        Sakaybrile<span style="color:var(--color-accent);">.</span>
      </a>

      <!-- Desktop nav -->
      <nav class="nav-desktop">
        <ul style="display:flex;gap:2rem;list-style:none;align-items:center;">
          <li><a href="/services/" class={`nav-link${pathname.startsWith('/services') ? ' active' : ''}`}>Services</a></li>
          <li><a href="/portfolio/" class={`nav-link${pathname.startsWith('/portfolio') ? ' active' : ''}`}>Portfolio</a></li>
          <li><a href="/blog/" class={`nav-link${pathname.startsWith('/blog') ? ' active' : ''}`}>Blog</a></li>
          <li><a href="/a-propos/" class={`nav-link${pathname.startsWith('/a-propos') ? ' active' : ''}`}>À propos</a></li>
          <li><DarkModeToggle /></li>
          <li><a href="/contact/" class="btn btn--primary" style="padding:0.5rem 1.25rem;font-size:0.9rem;">Devis gratuit</a></li>
        </ul>
      </nav>

      <!-- Mobile nav button -->
      <div style="display:flex;align-items:center;gap:1rem;">
        <DarkModeToggle />
        <button class="nav-mobile-btn" id="mobile-open" aria-label="Ouvrir le menu" aria-expanded="false" style="background:none;border:none;cursor:pointer;padding:0.5rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer itemscope itemtype="https://schema.org/LocalBusiness">
    <div class="container">
      <div class="footer-grid">
        <div data-reveal>
          <p class="footer-brand" itemprop="name">Sakaybrile Web Design</p>
          <p itemprop="description">Web designer indépendant en Guadeloupe. Création de sites internet professionnels, référencement SEO et e-commerce depuis 2019.</p>
          <p style="margin-top:1rem;font-size:0.85rem;" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
            📍 <span itemprop="addressLocality">Pointe-à-Pitre</span>, <span itemprop="addressRegion">Guadeloupe</span>
          </p>
          <div style="display:flex;gap:1rem;margin-top:1.25rem;">
            <a href="https://www.linkedin.com/in/sakaybrile" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="footer-social">in</a>
            <a href="https://www.instagram.com/sakaybrile_web" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social">ig</a>
          </div>
        </div>
        <div data-reveal data-delay="100">
          <p class="footer-title">Services</p>
          <ul>
            <li><a href="/services/creation-site-vitrine/">Création site vitrine</a></li>
            <li><a href="/services/creation-site-ecommerce/">Création e-commerce</a></li>
            <li><a href="/services/referencement-seo/">Référencement SEO</a></li>
            <li><a href="/services/">Tous les services</a></li>
          </ul>
        </div>
        <div data-reveal data-delay="200">
          <p class="footer-title">Informations</p>
          <ul>
            <li><a href="/portfolio/">Portfolio</a></li>
            <li><a href="/blog/">Blog & Conseils</a></li>
            <li><a href="/faq/">FAQ</a></li>
            <li><a href="/a-propos/">À propos</a></li>
          </ul>
        </div>
        <div data-reveal data-delay="300">
          <p class="footer-title">Contact</p>
          <ul>
            <li><a href="mailto:contact@sakaybrile.uk" itemprop="email">contact@sakaybrile.uk</a></li>
            <li><a href="tel:+590XXXXXXXX">+590 XX XX XX XX</a></li>
            <li><a href="/contact/">Demander un devis</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Sakaybrile Web Design — Web designer <span itemprop="areaServed">Guadeloupe</span></p>
        <nav style="display:flex;gap:1.5rem;">
          <a href="/mentions-legales/">Mentions légales</a>
          <a href="/sitemap-index.xml">Sitemap</a>
        </nav>
      </div>
    </div>
  </footer>

  <Preloader />
  <BackToTop />
  <FluidCursor />
  <SmoothScroll />
  <AnimationEngine />

  <style>
    /* ── Header ── */
    #site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border);
      transition: box-shadow 0.3s;
    }
    #site-header.scrolled { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }

    /* ── Footer ── */
    footer {
      background: #0f172a;
      color: #94a3b8;
      padding: 4rem 0 1.5rem;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 3rem;
    }
    .footer-brand {
      color: white !important;
      font-weight: 800;
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }
    .footer-title {
      color: white !important;
      font-weight: 600;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    footer ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    footer ul a { color: #94a3b8; font-size: 0.9rem; transition: color 0.2s; }
    footer ul a:hover { color: white; }
    .footer-social {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 50%;
      border: 1px solid #334155;
      color: #94a3b8;
      font-size: 0.8rem;
      font-weight: 700;
      transition: all 0.2s;
    }
    .footer-social:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .footer-bottom {
      border-top: 1px solid #1e293b;
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.8rem;
    }
    .footer-bottom a { color: #64748b; }
    .footer-bottom a:hover { color: white; }

    @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; } }
  </style>

  <script>
    // Header scroll effect
    const header = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      header?.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });

    // Mobile menu
    document.getElementById('mobile-open')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('open');
    });
    document.getElementById('mobile-close')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.remove('open');
    });
  </script>
</body>
</html>
